# WMS local development environment variables
# Copy these keys into your User Environment Variables or a local .env (do not commit real values).

JWT_SECRET=YOUR_BASE64_SECRET_MIN_32_BYTES
JWT_EXPIRATION=86400000
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

DB_USERNAME=postgres
DB_PASSWORD=your_db_password

GOOGLE_GENAI_API_KEY=your_google_genai_api_key
GOOGLE_GENAI_PROJECT_ID=demo-project

# Production bootstrap variables (for Vault profile)
VAULT_URI=http://127.0.0.1:8200
VAULT_TOKEN=your_vault_token
